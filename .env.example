# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Groq ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── SerpAPI (Google Places / Maps) ─────────────────────────────────────────────
SERPAPI_KEY=...

# ── Google PageSpeed Insights (Lighthouse proxy) ───────────────────────────────
PAGESPEED_API_KEY=...

# ── Instaloader ────────────────────────────────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── n8n (optional — campaign package generation) ───────────────────────────────
# Leave blank to skip n8n and use direct Groq call instead
N8N_WEBHOOK_URL=http://localhost:5678/webhook/campaign-generate
